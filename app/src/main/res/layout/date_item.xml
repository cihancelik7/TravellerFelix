<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="20dp"
    android:id="@+id/date_item_container"
    app:cardElevation="41dp"
    android:layout_margin="8dp"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/day_item_layout"
        android:layout_width="60dp"
        android:layout_height="100dp"
        android:orientation="vertical"
        android:padding="8dp">
        <TextView
            android:id="@+id/date_item_day_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MON"
            android:layout_gravity="center"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/textColor"/>

        <TextView
            android:id="@+id/date_item_day_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="28"
            android:textSize="16dp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:textColor="@color/textColor"
            android:layout_marginTop="4dp" />

        <View
            android:id="@+id/date_item_available"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginTop="4dp"
            android:layout_gravity="center"
            android:background="@drawable/dot_background"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>